ClientID=your_discord_client_id
ClientSecret=your_discord_client_secret
PORT=1500
token=your_discord_bot_token
APP_URL=http://localhost:1500
ANTHROPIC_API_KEY=your_anthropic_api_key
GUILD_ID=your_discord_server_id

# Notion — integration token + page IDs (shared with integration)
NOTION_TOKEN=your_notion_integration_token
NOTION_PAGE_FINANCE=your_finance_page_id
NOTION_PAGE_LEARNING=your_learning_page_id
NOTION_PAGE_IDEAS=your_ideas_page_id
NOTION_PAGE_PROJECTS=your_projects_page_id

# WhatsApp via GREEN-API
WHATSAPP_INSTANCE_ID=your_green_api_instance_id
WHATSAPP_TOKEN=your_green_api_token

# Google Sheets — finance tracker
SPREADSHEET_ID=your_google_spreadsheet_id
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/your/google_service_account.json

# YouTube transcript fetching (cloud deployments need at least one of these)
# Option 1: Supadata API key — https://supadata.ai
SUPADATA_API_KEY=your_supadata_api_key
# Option 2: YouTube cookies exported from browser (base64-encoded Netscape cookies.txt)
YOUTUBE_COOKIES_B64=
